# ==========================================
# Velora HD Backend Configuration Templates
# Rename this file to '.env' to use in development/production.
# ==========================================

# Port number on which the Express API server will listen
PORT=5000

# MongoDB Connection String URI
# - Local MongoDB instance: mongodb://127.0.0.1:27017/velorahd
# - MongoDB Atlas Cloud: mongodb+srv://<username>:<password>@cluster.mongodb.net/velorahd
MONGO_URI=mongodb://127.0.0.1:27017/velorahd

# JSON Web Token (JWT) secret key used to sign and authorize request tokens
# Replace this with a strong, random key in production environments
JWT_SECRET=your_jwt_secret_here_replace_me

# Server runtime mode ('development' or 'production')
# In development mode, verbose API request logs (Morgan dev) are enabled
NODE_ENV=development

# Nodemailer configuration for Gmail
# - EMAIL_USER: Your Gmail address (e.g. sender@gmail.com)
# - EMAIL_PASS: Your 16-character Gmail App Password (NOT your account password)
# - CONTACT_RECEIVER_EMAIL: The email address where you want to receive the contact messages
EMAIL_USER=velorahdwallart@gmail.com
EMAIL_PASS=ejiu erer qpxt ujpo
CONTACT_RECEIVER_EMAIL=velorahdwallart@gmail.com
